TEMPO_TESTNET_RPC_URL=https://rpc.moderato.tempo.xyz

# Optional. The CLI defaults Moderato fees to pathUSD when this is empty.
TEMPO_FEE_TOKEN=0x20c0000000000000000000000000000000000000

# Hosted web demo sessions. Set these in Vercel to enable 12-hour ephemeral sessions.
# Without these, the web app runs in local .poc mode.
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
POC_SESSION_TTL_SECONDS=43200
POC_HOSTED_AUTO_FAUCET=true
