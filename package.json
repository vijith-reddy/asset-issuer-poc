{
  "name": "asset-issuer-poc",
  "version": "1.0.0",
  "description": "USDV on Tempo POC CLI and contract workspace",
  "private": true,
  "type": "module",
  "packageManager": "npm@11.17.0",
  "scripts": {
    "poc": "tsx cli/index.ts",
    "web": "tsx apps/web/server.ts",
    "accounts:generate": "tsx scripts/helpers/generate-accounts.ts",
    "typecheck": "sh -c 'if find cli scripts apps -name \"*.ts\" -print -quit | grep -q .; then tsc --noEmit; else echo \"No TypeScript files to check yet\"; fi'",
    "build:contracts": "forge build",
    "test:contracts": "forge test",
    "vercel:build": "npm run typecheck"
  },
  "dependencies": {
    "commander": "^15.0.0",
    "dotenv": "^17.4.2",
    "viem": "^2.54.1"
  },
  "devDependencies": {
    "@types/node": "^26.1.0",
    "tsx": "^4.22.5",
    "typescript": "^6.0.3"
  }
}
